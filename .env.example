# GCP
PROJECT_ID=personal-assistant-lola
GOOGLE_CLIENT_ID=your-oauth-client-id
GOOGLE_CLIENT_SECRET=your-oauth-client-secret

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=generate-a-random-secret

# Token encryption — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Optional overrides
REGION=us-central1
SIGNATURE=Lola, Vladimir's AI Assistant
